{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "yanling.machine-first/v1 index.json",
  "type": "object",
  "required": ["schema_version", "generated_at", "modules", "packages", "topics", "symbols"],
  "properties": {
    "schema_version": {
      "const": "yanling.machine-first/v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "files"],
        "properties": {
          "module": { "type": "string", "minLength": 1 },
          "files": {
            "type": "object",
            "required": ["symbol_index", "package_dir", "topics"],
            "properties": {
              "symbol_index": { "type": "string" },
              "symbol_index_lite": { "type": "string" },
              "package_dir": { "type": "string" },
              "topics": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "name", "import_path", "directory", "package_file"],
        "properties": {
          "module": { "type": "string" },
          "name": { "type": "string" },
          "import_path": { "type": "string" },
          "directory": { "type": "string" },
          "doc": { "type": "string" },
          "package_file": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "name", "specifier"],
        "properties": {
          "module": { "type": "string" },
          "name": { "type": "string" },
          "specifier": { "type": "string" },
          "go_struct_name": { "type": "string" },
          "go_import_path": { "type": "string" },
          "doc": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "name", "kind", "import_path", "package", "package_file"],
        "properties": {
          "module": { "type": "string" },
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "import_path": { "type": "string" },
          "package": { "type": "string" },
          "doc": { "type": "string" },
          "package_file": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
