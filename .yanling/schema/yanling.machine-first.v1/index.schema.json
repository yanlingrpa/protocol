{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "yanling.machine-first/v1 index.json",
  "type": "object",
  "required": ["schema_version", "generated_at", "module", "files", "counts"],
  "properties": {
    "schema_version": {
      "const": "yanling.machine-first/v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "module": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "files": {
      "type": "object",
      "required": ["symbol_index", "package_dir", "topics"],
      "properties": {
        "symbol_index": { "type": "string" },
        "symbol_index_lite": { "type": "string" },
        "package_dir": { "type": "string" },
        "topics": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": ["packages", "topics", "symbols"],
      "properties": {
        "packages": { "type": "integer", "minimum": 0 },
        "topics": { "type": "integer", "minimum": 0 },
        "symbols": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
